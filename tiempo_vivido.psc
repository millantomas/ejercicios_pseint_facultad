Algoritmo tiempo_vivido
    Definir edad, meses, semanas, dias, horas Como Real
    
    Escribir Sin Saltar "Ingrese su edad en ańos: "
    Leer edad
    
    meses = edad * 12
    semanas = edad * 52
    dias = edad * 365
    horas = dias * 24
    
    Escribir "Meses vividos: ", meses
    Escribir "Semanas vividas: ", semanas
    Escribir "Dias vividos: ", dias
    Escribir "Horas vividas: ", horas
FinAlgoritmo