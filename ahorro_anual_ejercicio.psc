Algoritmo ahorro_anual_ejercicio
    Definir sueldo_semanal, ahorro_semanal, ahorro_anual Como Real
    
    Escribir Sin Saltar "Ingrese el sueldo semanal: "
    Leer sueldo_semanal
    
    ahorro_semanal = sueldo_semanal * 0.15
    ahorro_anual = ahorro_semanal * 48
    
    Escribir "El ahorro anual es: $", ahorro_anual
FinAlgoritmo