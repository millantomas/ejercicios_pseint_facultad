Algoritmo area_triangulo
	Definir base,altura,area Como Real
	
	Escribir Sin Saltar "Ingrese la base del triangulo: "
	Leer base
	
	Escribir Sin Saltar "ingrese la altura del triangulo: "
	Leer altura
	
	area = (base * altura) / 2
	
	Escribir Sin Saltar "El area del triangulo es: ",area
	
FinAlgoritmo
