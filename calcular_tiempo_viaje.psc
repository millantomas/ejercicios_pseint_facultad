Algoritmo calcular_tiempo_viaje
	Definir distancia,velocidad,tiempo Como Real
	
	Escribir Sin Saltar "Ingrese la distancia entre las ciudades km: "
	Leer distancia
	
	Escribir Sin Saltar "Ingrese la velocidad constante (km/h): "
	Leer velocidad
	
	tiempo = distancia / velocidad
	Escribir "El tiempo que tardara es: ", tiempo, " horass"
FinAlgoritmo
